# Use the uv-managed virtualenv (avoids direnv's bare `layout python` lookup).
export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$VIRTUAL_ENV/bin"

# boto3 default credential chain reads the standard names; map the dev keys.
export FORGE_OCR_S3_BUCKET="$(security find-generic-password -a "$USER" -s sax-key-forge-ocr-s3-bucket -w)"
export AWS_ACCESS_KEY_ID="$(security find-generic-password -a "$USER" -s sax-key-aws -w)"
export AWS_SECRET_ACCESS_KEY="$(security find-generic-password -a "$USER" -s sax-key-aws-secret -w)"
export AWS_REGION="us-east-2"
export AWS_OUTPUT="json"

export FORGE_DB_URL="$(security find-generic-password -a "$USER" -s dev-forge-database-url -w)"

## ----------------------------------------------------------------------
## Other API keys
## ----------------------------------------------------------------------

export OPENAI_API_KEY="$(security find-generic-password -a "$USER" -s sax-key-openai -w)"
export ANTHROPIC_API_KEY="$(security find-generic-password -a "$USER" -s sax-key-anthropic -w)"
export AIRTABLE_KEY="$(security find-generic-password -a "$USER" -s sax-key-airtable -w)"
export KAGI_API_KEY="$(security find-generic-password -a "$USER" -s sax-key-kagi -w)"
export ELEVEN_API_KEY="$(security find-generic-password -a "$USER" -s sax-key-eleven -w)"
export MISTRAL_API_KEY="$(security find-generic-password -a "$USER" -s sax-key-mistral -w)"
export FIRECRAWL_API_KEY="$(security find-generic-password -a "$USER" -s sax-key-firecrawl -w)"
export MXBAI_API_KEY="$(security find-generic-password -a "$USER" -s sax-key-mxbai -w)"

