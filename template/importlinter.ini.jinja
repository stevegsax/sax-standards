[importlinter]
root_package = {{ package_name }}
include_external_packages = True

[importlinter:contract:core-is-pure]
name = core may not import any shell module
type = forbidden
source_modules =
    {{ package_name }}.core
forbidden_modules =
    {{ package_name }}.settings
    {{ package_name }}.cli
{%- if include_db %}
    {{ package_name }}.db
{%- endif %}
{%- if include_temporal %}
    {{ package_name }}.workflows
    {{ package_name }}.activities
    {{ package_name }}.steps
    {{ package_name }}.worker
{%- endif %}
{%- if include_web %}
    {{ package_name }}.web
{%- endif %}
{%- if include_clients %}
    {{ package_name }}.clients
{%- endif %}
{%- if include_observability %}
    {{ package_name }}.observability
{%- endif %}

[importlinter:contract:core-no-io-libs]
name = core may not import I/O libraries
type = forbidden
source_modules =
    {{ package_name }}.core
forbidden_modules =
    sqlalchemy
    psycopg
    asyncpg
    httpx
    aiohttp
    requests
    boto3
    redis
    smtplib
    socket
    subprocess
{%- if include_temporal %}

[importlinter:contract:contracts-sandbox-safe]
name = core.contracts may not import asyncio or logging (Temporal sandbox safety)
type = forbidden
source_modules =
    {{ package_name }}.core.contracts
forbidden_modules =
    asyncio
    logging
{%- endif %}
