"""FastAPI app factory — create_app() + lifespan. No import-time I/O."""

from collections.abc import AsyncIterator
from contextlib import asynccontextmanager

from fastapi import FastAPI

from {{ package_name }}.web.{{ first_domain }}.routes import router as {{ first_domain }}_router


@asynccontextmanager
async def lifespan(_app: FastAPI) -> AsyncIterator[None]:
    """Build resources at startup, store on app.state; tear down on shutdown."""
    yield


def create_app() -> FastAPI:
    """Construct the FastAPI application."""
    application = FastAPI(lifespan=lifespan)
    application.include_router({{ first_domain }}_router)
    return application


app = create_app()
