"""Temporal worker — the single registration chokepoint."""

import asyncio
from concurrent.futures import ThreadPoolExecutor

from temporalio.client import Client
from temporalio.worker import Worker

from {{ package_name }}.activities import activities
from {{ package_name }}.core.contracts.constants import NAMESPACE, TASK_QUEUE
from {{ package_name }}.settings import Settings
from {{ package_name }}.workflows import workflows

_MAX_ACTIVITIES = 10


async def _run() -> None:
    """Connect and run the worker until cancelled."""
    settings = Settings()
    client = await Client.connect(settings.temporal_target, namespace=NAMESPACE)
    # House standard: DB/clients are sync; activities run in this thread pool.
    with ThreadPoolExecutor(max_workers=_MAX_ACTIVITIES) as executor:
        worker = Worker(
            client,
            task_queue=TASK_QUEUE,
            workflows=workflows(),
            activities=activities(),
            activity_executor=executor,
            max_concurrent_activities=_MAX_ACTIVITIES,
        )
        await worker.run()


def run_worker() -> None:
    """Entrypoint: run the Temporal worker."""
    asyncio.run(_run())
