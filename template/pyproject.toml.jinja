[project]
name = "{{ package_name | replace('_', '-') }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
authors = [{ name = "SAX Capital", email = "{{ author_email }}" }]
dependencies = [
    "pydantic>=2",
    "pydantic-settings>=2",
    "click>=8",
{%- if include_db %}
    "sqlalchemy>=2",
    "alembic>=1.13",
{%- endif %}
{%- if include_temporal %}
    "temporalio>=1.7",
{%- endif %}
{%- if include_web %}
    "fastapi>=0.115",
    "uvicorn>=0.30",
    "jinja2>=3",
{%- endif %}
{%- if include_observability %}
    "structlog>=24",
    "opentelemetry-sdk>=1.27",
{%- endif %}
]

[project.scripts]
{{ package_name }} = "{{ package_name }}.cli:main"

[dependency-groups]
dev = [
    "mypy>=1.11",
    "ruff>=0.6",
    "pytest>=8",
    "pytest-cov>=5",
    "hypothesis>=6",
    "import-linter>=2",
{%- if include_db %}
    "testcontainers[postgres]>=4",
{%- endif %}
{%- if include_temporal %}
    "pytest-asyncio>=0.24",
{%- endif %}
{%- if include_web %}
    "httpx>=0.27",
{%- endif %}
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
src = ["src", "tests"]
{%- if include_db %}
extend-exclude = ["src/{{ package_name }}/db/migrations"]
{%- endif %}

[tool.ruff.lint]
# House selection: security (S), docstrings (D), pyflakes dead-code (F401/F811/F841), bugbear (B).
select = ["E", "F", "W", "I", "S", "D", "B", "UP", "T20"]
ignore = ["D203", "D213"]

[tool.ruff.lint.per-file-ignores]
"tests/**" = ["S101", "D"]  # asserts and undocumented tests are fine

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.mypy]
python_version = "{{ python_version }}"
plugins = ["pydantic.mypy"]
strict = true
disallow_untyped_defs = true
warn_return_any = true
warn_unused_ignores = true
warn_redundant_casts = true
no_implicit_reexport = true
{%- if include_db %}
exclude = ["src/{{ package_name }}/db/migrations/"]
{%- endif %}

[tool.pytest.ini_options]
testpaths = ["tests"]
# importlib import mode so same-named test files in different domain dirs
# (tests/unit/<domain>/test_logic.py) don't collide once a project has 2+ domains.
{%- if has_shell %}
markers = [
    "integration: real ephemeral dependencies",
    "e2e: full-stack at the HTTP/CLI boundary",
]
addopts = "-m 'not integration and not e2e' --cov={{ package_name }} --cov-branch --import-mode=importlib"
{%- else %}
addopts = "--cov={{ package_name }} --cov-branch --import-mode=importlib"
{%- endif %}
{%- if include_temporal %}
asyncio_mode = "auto"
{%- endif %}

[tool.coverage.report]
# The blessed set the pyqc auditor also measures with: the only patterns the
# house guidelines mandate as unreachable (assert_never exhaustiveness arms).
exclude_also = [
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
    "assert_never\\(",
    "case _ as unreachable:",
]
